# Public site URL (used for metadata, sitemap, and contact emails)
NEXT_PUBLIC_SITE_URL=https://tuukkaleksi-github-io.vercel.app

# Resend — contact form (https://resend.com)
RESEND_API_KEY=re_xxxxxxxx
# Inbox that receives portfolio messages (must be verified in Resend until you add a domain)
CONTACT_TO_EMAIL=you@example.com
# Optional: defaults to Portfolio <onboarding@resend.dev> (Resend test sender without custom domain)
# CONTACT_FROM_EMAIL=Portfolio <onboarding@resend.dev>
# Optional: HMAC token secret (defaults to RESEND_API_KEY if unset)
# CONTACT_FORM_SECRET=long-random-string

# Optional: Cloudflare Turnstile — strongly recommended for bot protection (https://dash.cloudflare.com)
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=

# Postgres database (Neon Database) — optional
DATABASE_URL='postgresql://username:password@host:port/database'
