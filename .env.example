# Public site URL (metadata, contact)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Link to standalone Neon Drift app (portfolio project page)
NEXT_PUBLIC_NEON_DRIFT_URL=http://localhost:3000

# Resend (contact form)
RESEND_API_KEY=
CONTACT_TO_EMAIL=
CONTACT_FROM_EMAIL=

# Contact form HMAC (optional fallback)
CONTACT_FORM_SECRET=

# Cloudflare Turnstile (contact form when both keys are set)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
