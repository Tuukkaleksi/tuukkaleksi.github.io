# Public site URL (metadata, auth callbacks, emails)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Neon Postgres (leaderboard + pilot auth)
DATABASE_URL=

# Better Auth (pilot sign-in / register)
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Resend (contact form + auth emails)
RESEND_API_KEY=
CONTACT_TO_EMAIL=
CONTACT_FROM_EMAIL=
# Optional dedicated sender for auth emails (falls back to CONTACT_FROM_EMAIL)
AUTH_FROM_EMAIL=

# Contact form HMAC + Neon Drift run tokens (optional fallbacks)
CONTACT_FORM_SECRET=
NEON_DRIFT_SECRET=

# Cloudflare Turnstile (required on register when both keys are set)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Neon Drift feature flags
# Enable global leaderboard submit only after pilot auth is live and tested
NEXT_PUBLIC_NEON_DRIFT_GLOBAL_SUBMIT=false